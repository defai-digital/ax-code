{
  "name": "@ax-code/fs",
  "version": "0.1.0",
  "description": "Rust-powered file scanning and ignore engine for ax-code",
  "main": "index.js",
  "types": "index.d.ts",
  "napi": {
    "name": "ax-code-fs",
    "triples": {
      "defaults": false,
      "additional": [
        "aarch64-apple-darwin",
        "x86_64-apple-darwin",
        "x86_64-unknown-linux-gnu",
        "aarch64-unknown-linux-gnu",
        "x86_64-pc-windows-msvc"
      ]
    }
  },
  "files": [
    "index.js",
    "index.d.ts"
  ],
  "scripts": {
    "build": "napi build --manifest-path ../../crates/ax-code-fs/Cargo.toml --platform --release --js index.js --dts index.d.ts",
    "build:debug": "napi build --manifest-path ../../crates/ax-code-fs/Cargo.toml --platform --js index.js --dts index.d.ts"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.0.0"
  },
  "license": "MIT"
}
