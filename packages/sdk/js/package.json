{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@ax-code/sdk",
  "version": "2.2.0",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "typecheck": "tsgo --noEmit",
    "validate:openapi": "tsx ./script/validate-openapi.ts",
    "build": "tsx ./script/build.ts",
    "test": "vitest run"
  },
  "exports": {
    ".": "./dist/index.js",
    "./testing": "./dist/testing/index.js",
    "./programmatic": "./dist/programmatic/index.js",
    "./grpc": "./dist/grpc.js",
    "./grpc/node": "./dist/grpc-node.js",
    "./proto/ax_code/v1/headless.proto": "./dist/proto/ax_code/v1/headless.proto",
    "./headless": "./dist/headless.js",
    "./headless/client": "./dist/headless/client.js",
    "./headless/event": "./dist/headless/event.js",
    "./headless/projection": "./dist/headless/projection.js",
    "./v2": "./dist/v2/index.js",
    "./v2/client": "./dist/v2/client.js",
    "./v2/gen/client": "./dist/v2/gen/client/index.js",
    "./v2/server": "./dist/v2/server.js"
  },
  "files": [
    "dist"
  ],
  "devDependencies": {
    "@hey-api/openapi-ts": "0.90.10",
    "@tsconfig/node24": "catalog:",
    "@types/node": "catalog:",
    "@typescript/native-preview": "catalog:",
    "tsx": "4.22.4",
    "typescript": "catalog:",
    "vitest": "4.1.9",
    "zod": "catalog:"
  }
}
