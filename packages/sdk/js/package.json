{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@ax-code/sdk",
  "version": "2.1.0",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "typecheck": "tsgo --noEmit",
    "validate:openapi": "bun ./script/validate-openapi.ts",
    "build": "bun ./script/build.ts",
    "test": "bun test"
  },
  "exports": {
    ".": "./src/index.ts",
    "./testing": "./src/testing/index.ts",
    "./programmatic": "./src/programmatic/index.ts",
    "./grpc": "./src/grpc.ts",
    "./grpc/node": "./src/grpc-node.ts",
    "./proto/ax_code/v1/headless.proto": "./dist/proto/ax_code/v1/headless.proto",
    "./headless": "./src/headless.ts",
    "./headless/client": "./src/headless/client.ts",
    "./headless/event": "./src/headless/event.ts",
    "./headless/projection": "./src/headless/projection.ts"
  },
  "files": [
    "dist"
  ],
  "devDependencies": {
    "@hey-api/openapi-ts": "0.90.10",
    "@tsconfig/node22": "catalog:",
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "@typescript/native-preview": "catalog:",
    "zod": "catalog:"
  }
