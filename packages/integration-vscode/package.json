{
  "name": "ax-code-vscode",
  "version": "2.1.2",
  "repository": {
    "type": "git",
    "url": "https://github.com/defai-digital/ax-code"
  },
  "main": "./dist/extension.js",
  "devDependencies": {
    "@types/node": "20.x",
    "@types/vscode": "^1.94.0",
    "@typescript-eslint/eslint-plugin": "^8.31.1",
    "@typescript-eslint/parser": "^8.31.1",
    "@vscode/vsce": "^3.2.1",
    "esbuild": "^0.28.1",
    "eslint": "^9.25.1",
    "typescript": "^5.8.3",
    "vitest": "4.1.9"
  },
  "activationEvents": [
    "onStartupFinished",
    "onView:ax-code.chatView"
  ],
  "categories": [
    "AI",
    "Chat",
    "Programming Languages"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "ax-code",
          "title": "ax-code",
          "icon": "images/logo/activity-icon.png"
        }
      ]
    },
    "views": {
      "ax-code": [
        {
          "type": "webview",
          "id": "ax-code.chatView",
          "name": "Chat"
        }
      ]
    },
    "commands": [
      {
        "command": "ax-code.openChat",
        "title": "ax-code: Open Chat"
      },
      {
        "command": "ax-code.askAboutFile",
        "title": "ax-code: Explain This File"
      },
      {
        "command": "ax-code.fixFile",
        "title": "ax-code: Fix This File"
      },
      {
        "command": "ax-code.explainSelection",
        "title": "ax-code: Explain Selection"
      },
      {
        "command": "ax-code.reviewSelection",
        "title": "ax-code: Review Selection"
      },
      {
        "command": "ax-code.openTerminal",
        "title": "ax-code: Open Terminal",
        "icon": {
          "light": "images/logo/activity-icon.png",
          "dark": "images/logo/activity-icon.png"
        }
      },
      {
        "command": "ax-code.openNewTerminal",
        "title": "ax-code: Open Terminal (New Tab)",
        "icon": {
          "light": "images/logo/activity-icon.png",
          "dark": "images/logo/activity-icon.png"
        }
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "ax-code.openChat",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "ax-code.explainSelection",
          "group": "ax-code",
          "when": "editorHasSelection"
        },
        {
          "command": "ax-code.reviewSelection",
          "group": "ax-code",
          "when": "editorHasSelection"
        },
        {
          "command": "ax-code.askAboutFile",
          "group": "ax-code"
        },
        {
          "command": "ax-code.fixFile",
          "group": "ax-code"
        }
      ]
    },
    "keybindings": [
      {
        "command": "ax-code.openChat",
        "key": "ctrl+shift+a",
        "mac": "cmd+shift+a"
      },
      {
        "command": "ax-code.explainSelection",
        "key": "ctrl+alt+e",
        "mac": "cmd+alt+e",
        "when": "editorHasSelection && editorTextFocus"
      },
      {
        "command": "ax-code.openTerminal",
        "key": "ctrl+escape",
        "mac": "cmd+escape"
      }
    ],
    "configuration": {
      "title": "AX Code",
      "properties": {
        "axCode.binaryPath": {
          "type": "string",
          "default": "",
          "description": "Path to the ax-code binary. Leave empty to auto-detect (monorepo dev or PATH)."
        },
        "axCode.serverTimeoutMs": {
          "type": "number",
          "default": 90000,
          "minimum": 10000,
          "description": "Milliseconds to wait for ax-code serve to report 'listening' before failing."
        },
        "axCode.requestTimeoutMs": {
          "type": "number",
          "default": 600000,
          "minimum": 30000,
          "description": "Per-message timeout in milliseconds (default 10 minutes)."
        },
        "axCode.defaultModel": {
          "type": "string",
          "default": "",
          "description": "Default model in providerID/modelID form (e.g. anthropic/claude-opus-4-6). Overridable via the Model picker."
        }
      }
    }
  },
  "description": "AI coding agent for VS Code — powered by AX Code",
  "displayName": "AX Code",
  "engines": {
    "vscode": "^1.94.0"
  },
  "galleryBanner": {
    "color": "#000000",
    "theme": "dark"
  },
  "icon": "images/icon.png",
  "license": "Apache-2.0",
  "publisher": "defai-digital",
  "scripts": {
    "vscode:prepublish": "pnpm run package",
    "compile": "pnpm run check-types && pnpm run lint && node esbuild.js",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "pnpm run check-types && pnpm run lint && node esbuild.js --production",
    "package:vsix": "pnpm run package && vsce package --no-git-tag-version --no-update-package-json --no-dependencies --skip-license -o dist/ax-code-$npm_package_version.vsix",
    "check-types": "tsc --noEmit",
    "typecheck": "pnpm run check-types",
    "lint": "eslint src",
    "test:unit": "vitest run",
    "test": "pnpm run check-types && pnpm run lint && pnpm run test:unit"
  },
  "dependencies": {
    "@ax-code/sdk": "workspace:*",
    "marked": "^12"
  }
}
