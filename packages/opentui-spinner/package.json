{
  "name": "@ax-code/opentui-spinner",
  "version": "1.0.0",
  "description": "Vendored fork of @opentui/spinner — animated spinner renderable for terminal UIs. Independently maintained in the ax-code workspace.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      }
    },
    "./solid": {
      "import": {
        "types": "./dist/solid.d.mts",
        "default": "./dist/solid.mjs"
      }
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "dependencies": {
    "@ax-code/opentui-core": "workspace:*",
    "@ax-code/opentui-solid": "workspace:*"
  }
}
