{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@ax-code/desktop",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "license": "MIT",
  "main": "./dist/main.js",
  "scripts": {
    "dev": "bun ./src/main.ts --dev",
    "dev:dry-run": "bun ./src/main.ts --dry-run --dev",
    "build:main": "bun ./src/packaging/build.ts",
    "build": "pnpm --dir ../app run build && bun ./src/packaging/build.ts && bun ./src/main.ts --dry-run",
    "package:mac": "pnpm --dir ../app run build && bun ./src/packaging/mac.ts",
    "release:mac:preflight": "bun ./src/packaging/release-preflight.ts",
    "release:mac": "pnpm --dir ../app run build && bun ./src/packaging/release-mac.ts",
    "beta:check": "bun ./src/packaging/beta-readiness.ts",
    "beta:evidence": "bun ./src/packaging/beta-evidence.ts",
    "beta:collect": "bun ./src/packaging/beta-collect.ts",
    "smoke:renderer": "pnpm --dir ../app run build && bun ./src/packaging/build.ts && bun ./src/packaging/renderer-smoke.ts",
    "smoke:packaged": "bun ./src/packaging/smoke.ts",
    "typecheck": "tsgo --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "@ax-code/sdk": "workspace:*",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@tsconfig/node22": "catalog:",
    "@types/bun": "catalog:",
    "@types/node": "catalog:",
    "@typescript/native-preview": "catalog:",
    "electron": "catalog:",
    "typescript": "catalog:"
  }
}
