{
  "$schema": "https://json.schemastore.org/package.json",
  "version": "6.9.8",
  "name": "ax-code",
  "type": "module",
  "license": "Apache-2.0",
  "private": true,
  "scripts": {
    "typecheck": "tsgo --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "tsx script/test-groups.ts unit",
    "test:recovery": "tsx script/test-groups.ts recovery",
    "test:e2e": "tsx script/test-groups.ts e2e",
    "test:deterministic": "tsx script/test-groups.ts deterministic",
    "test:live": "tsx script/test-groups.ts live",
    "test:ci": "tsx script/test-ci.ts",
    "test:risk": "tsx script/test-risk.ts",
    "check:skills": "tsx script/check-skills.ts",
    "check:skills:all": "tsx script/check-skills.ts --all",
    "check:tui-layering": "tsx script/check-tui-layering.ts",
    "check:tui-snapshot": "node ../../script/node-ffi-runner.mjs --import tsx --import ../../script/solid-loader.mjs --conditions=node script/check-tui-snapshot.ts",
    "check:golden-frames": "node ../../script/node-ffi-runner.mjs --import tsx --conditions=node script/check-golden-frames.ts",
    "check:bun-compat": "tsx script/check-bun-compat.ts",
    "check:self-scan": "tsx script/self-scan.ts",
    "quality:rollout": "node ../../script/node-ffi-runner.mjs --import tsx --import ../../script/solid-loader.mjs --conditions=node script/quality-rollout.ts",
    "perf:index": "tsx script/perf-index.ts",
    "perf:report": "tsx script/perf-report.ts",
    "build": "tsx script/build-node-tui.ts",
    "build:node": "tsx script/build-node.ts",
    "build:node-tui": "tsx script/build-node-tui.ts",
    "tui:startup-smoke": "tsx script/tui-startup-smoke.ts",
    "dev": "node ../../script/node-ffi-runner.mjs --import tsx --import ../../script/solid-loader.mjs --conditions=node ./src/index-node-tui.ts",
    "db": "pnpm exec drizzle-kit"
  },
  "exports": {
    "./*": "./src/*.ts"
  },
  "imports": {
    "#db": {
      "node": "./src/storage/db.node.ts",
      "default": "./src/storage/db.node.ts"
    }
  },
  "devDependencies": {
    "@ax-code/script": "workspace:*",
    "@octokit/webhooks-types": "catalog:",
