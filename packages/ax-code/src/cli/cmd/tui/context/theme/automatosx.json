{
  "$schema": "https://raw.githubusercontent.com/defai-digital/ax-code/main/packages/ax-code/tui-theme.schema.json",
  "defs": {
    "darkBg": "#0a0d0b",
    "darkBgPanel": "#101512",
    "darkBgElement": "#161c18",
    "darkFg": "#d4d9d6",
    "darkFgMuted": "#6f7d75",
    "darkDeepGreen": "#15803d",
    "darkGreen": "#16a34a",
    "darkLightGreen": "#86efac",
    "darkMidGreen": "#57cf83",
    "darkPurple": "#a78bfa",
    "darkLightPurple": "#c4b5fd",
    "darkAmber": "#d9a514",
    "darkRed": "#ef6363",
    "lightBg": "#ffffff",
    "lightBgPanel": "#f3f6f4",
    "lightBgElement": "#e8eeea",
    "lightFg": "#18211c",
    "lightFgMuted": "#5c6962",
    "lightDeepGreen": "#15803d",
    "lightDarkGreen": "#166534",
    "lightGreen": "#16a34a",
    "lightPurple": "#7c3aed",
    "lightDeepPurple": "#6d28d9",
    "lightAmber": "#b45309",
    "lightRed": "#dc2626"
  },
  "theme": {
    "primary": { "dark": "darkGreen", "light": "lightDeepGreen" },
    "secondary": { "dark": "darkPurple", "light": "lightPurple" },
    "accent": { "dark": "darkLightGreen", "light": "lightGreen" },
    "brandGradientStart": { "dark": "darkLightGreen", "light": "lightGreen" },
    "brandGradientEnd": { "dark": "darkDeepGreen", "light": "lightDarkGreen" },
    "error": { "dark": "darkRed", "light": "lightRed" },
    "warning": { "dark": "darkAmber", "light": "lightAmber" },
    "success": { "dark": "darkGreen", "light": "lightGreen" },
    "info": { "dark": "darkPurple", "light": "lightPurple" },
    "text": { "dark": "darkFg", "light": "lightFg" },
    "textMuted": { "dark": "darkFgMuted", "light": "lightFgMuted" },
    "background": { "dark": "darkBg", "light": "lightBg" },
    "backgroundPanel": { "dark": "darkBgPanel", "light": "lightBgPanel" },
    "backgroundElement": { "dark": "darkBgElement", "light": "lightBgElement" },
    "border": { "dark": "#222a25", "light": "#d4ddd7" },
    "borderActive": { "dark": "darkDeepGreen", "light": "lightDeepGreen" },
    "borderSubtle": { "dark": "#171e1a", "light": "#e3eae5" },
    "diffAdded": { "dark": "darkMidGreen", "light": "lightGreen" },
    "diffRemoved": { "dark": "darkRed", "light": "lightRed" },
    "diffContext": { "dark": "darkFgMuted", "light": "lightFgMuted" },
    "diffHunkHeader": { "dark": "darkGreen", "light": "lightDeepGreen" },
    "diffHighlightAdded": { "dark": "darkMidGreen", "light": "lightGreen" },
    "diffHighlightRemoved": { "dark": "darkRed", "light": "lightRed" },
    "diffAddedBg": { "dark": "#0e2917", "light": "#dcfce7" },
    "diffRemovedBg": { "dark": "#331114", "light": "#fee2e2" },
    "diffContextBg": { "dark": "#0d120f", "light": "lightBgPanel" },
    "diffLineNumber": { "dark": "#33403a", "light": "#9ab0a4" },
    "diffAddedLineNumberBg": { "dark": "#0b2113", "light": "#c8f0d4" },
    "diffRemovedLineNumberBg": { "dark": "#2a0e11", "light": "#fbd5d5" },
    "markdownText": { "dark": "darkFg", "light": "lightFg" },
    "markdownHeading": { "dark": "darkGreen", "light": "lightDeepGreen" },
    "markdownLink": { "dark": "darkPurple", "light": "lightPurple" },
    "markdownLinkText": { "dark": "darkLightPurple", "light": "lightDeepPurple" },
    "markdownCode": { "dark": "darkLightPurple", "light": "lightDeepPurple" },
    "markdownBlockQuote": { "dark": "darkFgMuted", "light": "lightFgMuted" },
    "markdownEmph": { "dark": "darkFg", "light": "lightFg" },
    "markdownStrong": { "dark": "#dfe4e1", "light": "#101713" },
    "markdownHorizontalRule": { "dark": "#222a25", "light": "#d4ddd7" },
    "markdownListItem": { "dark": "darkGreen", "light": "lightDeepGreen" },
    "markdownListEnumeration": { "dark": "darkPurple", "light": "lightPurple" },
    "markdownImage": { "dark": "darkPurple", "light": "lightPurple" },
    "markdownImageText": { "dark": "darkLightPurple", "light": "lightDeepPurple" },
    "markdownCodeBlock": { "dark": "darkFg", "light": "lightFg" },
    "syntaxComment": { "dark": "#56645c", "light": "#6b7a71" },
    "syntaxKeyword": { "dark": "darkPurple", "light": "lightPurple" },
    "syntaxFunction": { "dark": "darkMidGreen", "light": "lightDeepGreen" },
    "syntaxVariable": { "dark": "darkFg", "light": "lightFg" },
    "syntaxString": { "dark": "#4cb874", "light": "#2f8f57" },
    "syntaxNumber": { "dark": "darkLightPurple", "light": "lightDeepPurple" },
    "syntaxType": { "dark": "#9d8df0", "light": "lightDeepPurple" },
    "syntaxOperator": { "dark": "#75847b", "light": "#64748b" },
    "syntaxPunctuation": { "dark": "#75847b", "light": "#64748b" }
  }
}
