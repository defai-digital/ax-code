{
  "$schema": "https://raw.githubusercontent.com/defai-digital/ax-code/main/packages/ax-code/tui-theme.schema.json",
  "defs": {
    "darkBg": "#232a2d",
    "darkBgPanel": "#2a3235",
    "darkBgElement": "#323b3e",
    "darkFg": "#ccd5cf",
    "darkFgMuted": "#7f8d85",
    "darkSage": "#95c195",
    "darkDeepSage": "#74a877",
    "darkLightSage": "#aed3a0",
    "darkAqua": "#87c5ad",
    "darkPurple": "#b8a3e3",
    "darkBlue": "#8ab8d0",
    "darkAmber": "#d6b97c",
    "darkRed": "#e08585",
    "lightBg": "#f7f8f6",
    "lightBgPanel": "#eef1ed",
    "lightBgElement": "#e4e9e4",
    "lightFg": "#3a443e",
    "lightFgMuted": "#6c7a72",
    "lightSage": "#4e8d57",
    "lightDeepSage": "#2f6d46",
    "lightAqua": "#3a8f74",
    "lightPurple": "#7d5bbe",
    "lightDeepPurple": "#6d4fae",
    "lightBlue": "#3d7ea6",
    "lightAmber": "#a8771c",
    "lightRed": "#c25454"
  },
  "theme": {
    "primary": { "dark": "darkSage", "light": "lightSage" },
    "secondary": { "dark": "darkPurple", "light": "lightPurple" },
    "accent": { "dark": "darkAqua", "light": "lightAqua" },
    "brandGradientStart": { "dark": "darkLightSage", "light": "lightSage" },
    "brandGradientEnd": { "dark": "darkDeepSage", "light": "lightDeepSage" },
    "error": { "dark": "darkRed", "light": "lightRed" },
    "warning": { "dark": "darkAmber", "light": "lightAmber" },
    "success": { "dark": "darkSage", "light": "lightSage" },
    "info": { "dark": "darkBlue", "light": "lightBlue" },
    "text": { "dark": "darkFg", "light": "lightFg" },
    "textMuted": { "dark": "darkFgMuted", "light": "lightFgMuted" },
    "background": { "dark": "darkBg", "light": "lightBg" },
    "backgroundPanel": { "dark": "darkBgPanel", "light": "lightBgPanel" },
    "backgroundElement": { "dark": "darkBgElement", "light": "lightBgElement" },
    "border": { "dark": "#3d4649", "light": "#d4dad4" },
    "borderActive": { "dark": "darkDeepSage", "light": "lightSage" },
    "borderSubtle": { "dark": "#333c3f", "light": "#e2e7e1" },
    "diffAdded": { "dark": "darkSage", "light": "lightSage" },
    "diffRemoved": { "dark": "darkRed", "light": "lightRed" },
    "diffContext": { "dark": "darkFgMuted", "light": "lightFgMuted" },
    "diffHunkHeader": { "dark": "darkBlue", "light": "lightBlue" },
    "diffHighlightAdded": { "dark": "darkSage", "light": "lightSage" },
    "diffHighlightRemoved": { "dark": "darkRed", "light": "lightRed" },
    "diffAddedBg": { "dark": "#2e3b2f", "light": "#e1eede" },
    "diffRemovedBg": { "dark": "#3e2e30", "light": "#f6e3e1" },
    "diffContextBg": { "dark": "#272f32", "light": "lightBgPanel" },
    "diffLineNumber": { "dark": "#515c56", "light": "#aab5ac" },
    "diffAddedLineNumberBg": { "dark": "#28342a", "light": "#d3e4cf" },
    "diffRemovedLineNumberBg": { "dark": "#362a2c", "light": "#eed6d3" },
    "markdownText": { "dark": "darkFg", "light": "lightFg" },
    "markdownHeading": { "dark": "darkSage", "light": "lightSage" },
    "markdownLink": { "dark": "darkBlue", "light": "lightBlue" },
    "markdownLinkText": { "dark": "darkAqua", "light": "lightAqua" },
    "markdownCode": { "dark": "darkPurple", "light": "lightDeepPurple" },
    "markdownBlockQuote": { "dark": "darkFgMuted", "light": "lightFgMuted" },
    "markdownEmph": { "dark": "darkFg", "light": "lightFg" },
    "markdownStrong": { "dark": "#dde5df", "light": "#2b332e" },
    "markdownHorizontalRule": { "dark": "#3d4649", "light": "#d4dad4" },
    "markdownListItem": { "dark": "darkSage", "light": "lightSage" },
    "markdownListEnumeration": { "dark": "darkAqua", "light": "lightAqua" },
    "markdownImage": { "dark": "darkBlue", "light": "lightBlue" },
    "markdownImageText": { "dark": "darkAqua", "light": "lightAqua" },
    "markdownCodeBlock": { "dark": "darkFg", "light": "lightFg" },
    "syntaxComment": { "dark": "#6f7d75", "light": "#8a958d" },
    "syntaxKeyword": { "dark": "darkPurple", "light": "lightPurple" },
    "syntaxFunction": { "dark": "darkSage", "light": "lightSage" },
    "syntaxVariable": { "dark": "darkFg", "light": "lightFg" },
    "syntaxString": { "dark": "darkAqua", "light": "lightAqua" },
    "syntaxNumber": { "dark": "darkAmber", "light": "lightAmber" },
    "syntaxType": { "dark": "darkBlue", "light": "lightBlue" },
    "syntaxOperator": { "dark": "#a4b0a8", "light": "#67746c" },
    "syntaxPunctuation": { "dark": "#a4b0a8", "light": "#67746c" }
  }
}
