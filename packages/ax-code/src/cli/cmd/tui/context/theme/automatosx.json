{
  "$schema": "https://raw.githubusercontent.com/defai-digital/ax-code/main/packages/ax-code/tui-theme.schema.json",
  "defs": {
    "darkBg": "#0c1210",
    "darkBgPanel": "#121a16",
    "darkBgElement": "#18231e",
    "darkFg": "#c9d6cf",
    "darkFgMuted": "#76897e",
    "darkEmerald": "#10b981",
    "darkMint": "#34d399",
    "darkTeal": "#14b8a6",
    "darkGreen": "#22c55e",
    "darkLime": "#84cc16",
    "darkAmber": "#fbbf24",
    "darkRed": "#f87171",
    "darkBlue": "#60a5fa",
    "darkViolet": "#c4b5fd",
    "lightBg": "#ffffff",
    "lightBgPanel": "#f2f7f4",
    "lightBgElement": "#e6efe9",
    "lightFg": "#1a231e",
    "lightFgMuted": "#5a6b61",
    "lightEmerald": "#059669",
    "lightTeal": "#0d9488",
    "lightGreen": "#16a34a",
    "lightLime": "#65a30d",
    "lightAmber": "#b45309",
    "lightRed": "#dc2626",
    "lightBlue": "#2563eb",
    "lightViolet": "#7c3aed"
  },
  "theme": {
    "primary": { "dark": "darkEmerald", "light": "lightEmerald" },
    "secondary": { "dark": "darkTeal", "light": "lightTeal" },
    "accent": { "dark": "darkLime", "light": "lightLime" },
    "brandGradientStart": { "dark": "darkMint", "light": "lightTeal" },
    "brandGradientEnd": { "dark": "#059669", "light": "lightEmerald" },
    "error": { "dark": "darkRed", "light": "lightRed" },
    "warning": { "dark": "darkAmber", "light": "lightAmber" },
    "success": { "dark": "darkGreen", "light": "lightGreen" },
    "info": { "dark": "darkBlue", "light": "lightBlue" },
    "text": { "dark": "darkFg", "light": "lightFg" },
    "textMuted": { "dark": "darkFgMuted", "light": "lightFgMuted" },
    "background": { "dark": "darkBg", "light": "lightBg" },
    "backgroundPanel": { "dark": "darkBgPanel", "light": "lightBgPanel" },
    "backgroundElement": { "dark": "darkBgElement", "light": "lightBgElement" },
    "border": { "dark": "#27352e", "light": "#d3dfd8" },
    "borderActive": { "dark": "darkEmerald", "light": "lightEmerald" },
    "borderSubtle": { "dark": "#1c2722", "light": "#e2ebe5" },
    "diffAdded": { "dark": "darkGreen", "light": "lightGreen" },
    "diffRemoved": { "dark": "darkRed", "light": "lightRed" },
    "diffContext": { "dark": "darkFgMuted", "light": "lightFgMuted" },
    "diffHunkHeader": { "dark": "darkEmerald", "light": "lightEmerald" },
    "diffHighlightAdded": { "dark": "darkGreen", "light": "lightGreen" },
    "diffHighlightRemoved": { "dark": "darkRed", "light": "lightRed" },
    "diffAddedBg": { "dark": "#11301d", "light": "#dcfce7" },
    "diffRemovedBg": { "dark": "#3a1417", "light": "#fee2e2" },
    "diffContextBg": { "dark": "#0f1613", "light": "lightBgPanel" },
    "diffLineNumber": { "dark": "#3b4a42", "light": "#9ab0a4" },
    "diffAddedLineNumberBg": { "dark": "#0d2818", "light": "#c8f0d4" },
    "diffRemovedLineNumberBg": { "dark": "#311014", "light": "#fbd5d5" },
    "markdownText": { "dark": "darkFg", "light": "lightFg" },
    "markdownHeading": { "dark": "darkEmerald", "light": "lightEmerald" },
    "markdownLink": { "dark": "darkTeal", "light": "lightTeal" },
    "markdownLinkText": { "dark": "darkMint", "light": "#0f766e" },
    "markdownCode": { "dark": "darkViolet", "light": "lightViolet" },
    "markdownBlockQuote": { "dark": "darkFgMuted", "light": "lightFgMuted" },
    "markdownEmph": { "dark": "darkFg", "light": "lightFg" },
    "markdownStrong": { "dark": "#dde8e2", "light": "#101713" },
    "markdownHorizontalRule": { "dark": "#27352e", "light": "#d3dfd8" },
    "markdownListItem": { "dark": "darkEmerald", "light": "lightEmerald" },
    "markdownListEnumeration": { "dark": "darkTeal", "light": "lightTeal" },
    "markdownImage": { "dark": "darkTeal", "light": "lightTeal" },
    "markdownImageText": { "dark": "darkMint", "light": "#0f766e" },
    "markdownCodeBlock": { "dark": "darkFg", "light": "lightFg" },
    "syntaxComment": { "dark": "#6d7f76", "light": "#6b7a71" },
    "syntaxKeyword": { "dark": "darkEmerald", "light": "lightEmerald" },
    "syntaxFunction": { "dark": "darkMint", "light": "lightTeal" },
    "syntaxVariable": { "dark": "darkFg", "light": "lightFg" },
    "syntaxString": { "dark": "#52d199", "light": "#4d7c0f" },
    "syntaxNumber": { "dark": "darkAmber", "light": "lightAmber" },
    "syntaxType": { "dark": "#7fb0e8", "light": "lightBlue" },
    "syntaxOperator": { "dark": "#8fa39a", "light": "#64748b" },
    "syntaxPunctuation": { "dark": "#8fa39a", "light": "#64748b" }
  }
}
