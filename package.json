{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "ax-code",
  "description": "AI-powered development tool",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.4",
  "workspaces": [
    "packages/*",
    "!packages/ax-code-render-native",
    "packages/sdk/js",
    "desktop/packages/*"
  ],
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev": "pnpm --dir packages/ax-code exec node ../../script/node-ffi-runner.mjs --env-file-if-exists=../../.env --import tsx --import ../../script/solid-loader.mjs --conditions=node src/index-node-tui.ts",
    "cli": "pnpm --dir packages/ax-code exec node ../../script/node-ffi-runner.mjs --import tsx --import ../../script/solid-loader.mjs --conditions=node src/index-node-tui.ts",
    "setup:cli": "tsx script/setup-cli.ts",
    "check:structure": "tsx script/structure.ts",
    "check:no-cost": "tsx script/check-no-cost.ts",
    "check:openapi": "pnpm --dir packages/sdk/js run validate:openapi",
    "check:self-scan": "pnpm --dir packages/ax-code run check:self-scan",
    "check:desktop-boundaries": "tsx script/check-desktop-boundaries.ts",
    "check:desktop-boundaries:strict": "tsx script/check-desktop-boundaries.ts --fail-on-violation",
    "check:desktop-electron-runtime": "node desktop/scripts/check-electron-runtime.mjs",
    "check:desktop-endpoint-contracts": "node desktop/scripts/check-endpoint-contracts.mjs",
    "check:desktop-ipc-contracts": "node desktop/scripts/check-desktop-ipc-contracts.mjs",
    "check:desktop-package-tests": "node desktop/scripts/check-package-test-scripts.mjs",
    "desktop:dev": "turbo run dev --filter=@ax-code/electron",
    "desktop:build": "turbo run build --filter=@ax-code/electron",
    "desktop:typecheck": "pnpm --dir packages/sdk/js run build && pnpm --filter \"./desktop/packages/*\" --if-present run type-check",
    "desktop:test": "pnpm --dir packages/sdk/js run build && pnpm --filter \"./desktop/packages/*\" --if-present run test",
    "desktop:lint": "pnpm --filter \"./desktop/packages/*\" --if-present run lint",
    "desktop:smoke:packaged": "node desktop/packages/electron/scripts/smoke-packaged-app.mjs",
    "release:cli": "pnpm run sign:release && pnpm run publish:github",
    "release:desktop": "./desktop/scripts/publish-github-release.sh",
    "release:all": "pnpm run release:cli && pnpm run release:desktop",
    "typecheck": "pnpm -r --if-present run typecheck",
    "build:native": "tsx script/build-native.ts",
    "build:native:debug": "tsx script/build-native.ts --debug",
    "publish:github": "tsx script/publish-github-release.ts",
    "sign:release": "tsx script/sign-release-assets.ts",
    "prepare": "husky",
    "postinstall": "node desktop/scripts/fix-node-pty-permissions.mjs",
    "test:scripts": "vitest run",
    "test": "echo 'do not run tests from root (use test:scripts for root script suites)' && exit 1"
  },
  "devDependencies": {
    "@actions/artifact": "5.0.1",
    "@eslint/js": "^9.33.0",
    "@types/mime-types": "catalog:",
    "@types/node": "catalog:",
    "@typescript/native-preview": "catalog:",
    "eslint": "^9.33.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "fast-glob": "catalog:",
    "globals": "^16.3.0",
    "husky": "9.1.7",
    "prettier": "3.6.2",
    "semver": "catalog:",
    "tsx": "^4.22.4",
    "turbo": "2.9.14",
    "typescript-eslint": "^8.39.1",
    "vitest": "4.1.9"
  },
  "dependencies": {
    "@ax-code/plugin": "workspace:*",
    "@ax-code/script": "workspace:*",
    "@ax-code/sdk": "workspace:*",
    "typescript": "catalog:"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/defai-digital/ax-code"
  },
  "license": "Apache-2.0",
  "prettier": {
    "semi": false,
    "printWidth": 120
  },
  "trustedDependencies": [
    "@ax-code/diff",
    "@ax-code/fs",
    "@ax-code/index-core",
    "@ax-code/terminal",
    "@ax-code/parser",
    "esbuild",
    "protobufjs",
    "tree-sitter",
    "tree-sitter-bash",
    "electron",
    "node-pty-prebuilt-multiarch",
    "web-tree-sitter"
  ],
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "node-pty-prebuilt-multiarch"
    ],
    "overrides": {
      "serialize-javascript": ">=7.0.5",
      "seroval": ">=1.4.1",
      "diff@<8.0.3": "8.0.3",
      "undici@<6.27.0": "6.27.0",
      "undici@>=7.0.0 <7.28.0": "7.28.0",
      "tar@<7.5.16": "7.5.19",
      "@hono/node-server@<1.19.13": "1.19.13",
      "postcss@<8.5.10": "8.5.10",
      "fast-xml-parser@<5.7.0": "5.7.0",
      "protobufjs@<7.6.3": "7.6.3",
      "@protobufjs/utf8@<1.1.1": "1.1.1",
      "fast-uri@<3.1.2": "3.1.2",
      "fast-xml-builder@<1.1.7": "1.1.7",
      "ws@<8.21.0": "8.21.0",
      "prismjs@<1.30.0": "1.30.0",
      "brace-expansion@>=5.0.0 <5.0.6": "5.0.6",
      "ip-address@<10.1.1": "10.1.1",
      "qs@<6.15.2": "6.15.2",
      "uuid@<14.0.0": "14.0.0",
      "tmp@<0.2.7": "0.2.7",
      "esbuild@<0.28.1": "0.28.1",
      "markdown-it@<14.2.0": "14.2.0",
      "@opentelemetry/core@<2.8.0": "2.8.0",
      "form-data@<4.0.6": "4.0.6",
      "js-yaml@<4.2.0": "4.2.0",
      "@babel/core@<7.29.6": "7.29.6"
    },
    "peerDependencyRules": {},
    "patchedDependencies": {
      "@standard-community/standard-openapi@0.2.9": "patches/@standard-community%2Fstandard-openapi@0.2.9.patch",
      "gray-matter@4.0.3": "patches/gray-matter@4.0.3.patch",
      "@msgpack/msgpack@3.1.3": "patches/@msgpack__msgpack@3.1.3.patch",
      "node-pty-prebuilt-multiarch@0.10.1-pre.5": "patches/node-pty-prebuilt-multiarch@0.10.1-pre.5.patch"
    }
  }
}
