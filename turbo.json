{
  "$schema": "https://v2-8-13.turborepo.dev/schema.json",
  "globalEnv": ["CI", "AX_CODE_DISABLE_SHARE"],
  "globalPassThroughEnv": ["CI", "AX_CODE_DISABLE_SHARE"],
  "tasks": {
    "typecheck": {},
    "build": {
      "dependsOn": [],
      "outputs": ["dist/**"]
    },
    "ax-code-desktop#build": {
      "dependsOn": ["@ax-code/sdk#build", "@openchamber/ui#build"],
      "inputs": ["$TURBO_DEFAULT$", "../ui/src/**", "../../../packages/sdk/js/**"],
      "outputs": ["dist/**"]
    },
    "@ax-code/electron#build": {
      "dependsOn": ["ax-code-desktop#build"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "../web/src/**",
        "../web/server/**",
        "../web/bin/**",
        "../web/package.json",
        "../ui/src/**",
        "../../../packages/sdk/js/**"
      ],
      "outputs": ["dist/**", "out/**"]
    },
    "@ax-code/electron#dev": {
      "dependsOn": ["@ax-code/sdk#build"],
      "cache": false,
      "persistent": true
    },
    "ax-code#test": {
      "dependsOn": ["^build"],
      "outputs": []
    }
  }
}
